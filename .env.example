# AWS Region where your Cognito User Pool is deployed
VITE_AWS_REGION=us-east-1

# Cognito User Pool ID (from AWS Console > Cognito > User Pools > your pool > Pool ID)
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# Cognito App Client ID — use the Google/OAuth client
VITE_COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Cognito Hosted UI domain (without https://)
# AWS Console → Cognito → User Pools → [your pool] → App integration tab → Domain section
VITE_COGNITO_HOSTED_UI_DOMAIN=your-prefix.auth.us-east-1.amazoncognito.com

# OAuth redirect URLs — must match what's registered in the Cognito App Client settings
# Local dev:
VITE_COGNITO_REDIRECT_SIGN_IN=http://localhost:5173/auth/callback
VITE_COGNITO_REDIRECT_SIGN_OUT=http://localhost:5173/login

# Production (uncomment and update):
# VITE_COGNITO_REDIRECT_SIGN_IN=https://your-domain.com/auth/callback
# VITE_COGNITO_REDIRECT_SIGN_OUT=https://your-domain.com/login
